# ══════════════════════════════════════════════════════════════════════════════
# Gunter AI v2.0 — sample.env
# Copy this file to .env and fill in your values.
# Never commit .env to GitHub — it contains your private API keys.
# ══════════════════════════════════════════════════════════════════════════════

# ── Wake Mode ─────────────────────────────────────────────────────────────────
# text       → Type questions via keyboard (recommended for desktop/laptop)
# manual     → Press LISTEN button, then speak into microphone
# picovoice  → "Hey Gunter" wake word (requires Picovoice API key + hotspot)
WAKE_MODE="text"

# ── LLM Mode (legacy fallback) ────────────────────────────────────────────────
# NOTE: In v2.0, the active provider is set via Settings → API Providers.
# This setting is only used if no provider key is configured in providers.json.
# local  → Ollama (fully offline, no API key needed)
# claude → Anthropic Claude API (requires network)
LLM_MODE="local"

# ── Local Ollama model (used when LLM_MODE=local) ────────────────────────────
LOCAL_MODEL=llama3.2:3b

# ── Legacy Anthropic key (optional — use Settings panel instead) ──────────────
# If you set your Anthropic key here, Gunter will use it when LLM_MODE=claude.
# For multi-provider support, use Settings → API Providers in the app instead.
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# ── Claude model (used with legacy ANTHROPIC_API_KEY above) ──────────────────
# claude-haiku-4-5-20251001   → Fast and affordable (~$0.01/session)
# claude-sonnet-4-6           → More capable (~$0.20/session)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Picovoice (only needed for WAKE_MODE=picovoice) ──────────────────────────
# Free API key available at https://console.picovoice.ai/
PICOVOICE_API_KEY="your-picovoice-api-key-here"
